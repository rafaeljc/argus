<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
  "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
  "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
  <!-- Integration test classes use the *IT suffix per backend testing conventions. -->
  <suppress checks="AbbreviationAsWordInName" files="[\\/]src[\\/]test[\\/]java[\\/].*IT\.java$"/>
</suppressions>
